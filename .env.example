# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database (optional - uses SQLite by default)
# DATABASE_URL=postgres://user:password@localhost:5432/cloudstorage

# Redis/Celery (optional - required for background tasks)
REDIS_URL=redis://localhost:6379/0

# Image Compression
IMAGE_COMPRESSION_QUALITY=85
MAX_IMAGE_WIDTH=1920
MAX_IMAGE_HEIGHT=1080

# Google Drive API
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/cloud/google/callback/

# Dropbox API
# Create app at: https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REDIRECT_URI=http://localhost:8000/cloud/dropbox/callback/

# OneDrive API
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
ONEDRIVE_CLIENT_ID=your-onedrive-client-id
ONEDRIVE_CLIENT_SECRET=your-onedrive-client-secret
ONEDRIVE_REDIRECT_URI=http://localhost:8000/cloud/onedrive/callback/

# MEGA (uses email/password)
MEGA_EMAIL=your-mega-email@example.com
MEGA_PASSWORD=your-mega-password
